# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/road_damage

# Telegram Bot (получить у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# FastAPI URL (для бота)
API_BASE_URL=http://localhost:8000

# Roboflow API Key (для скачивания датасета)
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# API-ключ для защиты эндпоинтов (оставьте пустым для отключения)
API_SECRET_KEY=

# CORS: разрешённые домены через запятую
ALLOWED_ORIGINS=http://localhost:3000
